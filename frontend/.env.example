# Stacks Clicker Environment Variables
# Copy this file to .env and update the values for your environment

# =============================================================================
# Required Variables
# =============================================================================

# WalletConnect Project ID (Required)
# Get yours at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# =============================================================================
# Optional Variables
# =============================================================================

# Enable/Disable Debug Mode
# Set to 'true' to see detailed logs in the console
# Default: false
VITE_DEBUG=true

# Stacks Network Mode
# Options: mainnet, testnet, devnet
# Default: mainnet
VITE_STACKS_NETWORK=mainnet

# Contract deployer address used by clicker/tipjar/quickpoll
# Update this to the principal that deployed your contracts
VITE_DEPLOYER_ADDRESS=SP5K2RHMSBH4PAP4PGX77MCVNK1ZEED07CWX9TJT

# API Key for optional price tracking
# Get a free key at https://www.coingecko.com/api
VITE_COINGECKO_API_KEY=
